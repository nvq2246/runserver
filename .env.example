# Vercel Backend Configuration for CockroachDB
# Copy this file to .env and fill in your actual values

# ============================================
# Database Configuration
# ============================================
# Get this from your CockroachDB Cloud console
# Format: postgresql://user:password@host:26257/database?sslmode=require
DATABASE_URL=postgresql://your_username:your_password@your_cluster.crdb.io:26257/taskmanagement?sslmode=require

# ============================================
# Node Environment
# ============================================
NODE_ENV=production
PORT=3000
